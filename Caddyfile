# Caddyfile for MCP Research Server
# Tailscale Funnel handles HTTPS termination, so Caddy only needs HTTP
# Caddy runs on host network to be reachable by Funnel at 127.0.0.1:80

# HTTP listener - Tailscale Funnel forwards HTTPS here
:80 {
    # MCP server is exposed via Docker's published port or via Docker bridge
    reverse_proxy localhost:8000

    log {
        output stdout
        format console
    }
}
