# MCP Server Configuration

# SECURITY: Generate strong passwords for production
# Example: openssl rand -base64 32

# Tailscale Auth Key (get from https://login.tailscale.com/admin/settings/keys)
TS_AUTHKEY=tskey-auth-replace-with-your-key-here

# Tailscale MagicDNS Configuration
# Find your tailnet domain at: https://login.tailscale.com/admin/dns
# Example: If your tailnet is "example.ts.net" and machine is "mcp-server"
#          TAILNET_DOMAIN=example.ts.net
#          TAILNET_MACHINE_NAME=mcp-server
# Full URL would be: https://mcp-server.example.ts.net
TAILNET_DOMAIN=your-tailnet.ts.net
TAILNET_MACHINE_NAME=mcp-server

# SearXNG Secret (generate with: openssl rand -hex 32)
SEARXNG_SECRET=

# PostgreSQL Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=mcp_server
POSTGRES_USER=postgres
# WARNING: Change this password for production!
# Generate: openssl rand -base64 24
POSTGRES_PASSWORD=postgres

# External Services
SEARXNG_URL=http://searxng:8080

# Celery Queue
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# API Settings
MCP_HOST=0.0.0.0
MCP_PORT=8000

# CORS Allowed Origins (comma-separated)
# For Tailscale/localhost: http://localhost:8000,http://127.0.0.1:8000
# To allow all (NOT recommended for public): *
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:3000
