# Llama.cpp Router Caddyfile
# Routes requests to the appropriate llama.cpp backend

{
    admin localhost:2019
    auto_https off
}

:8080 {
    # Health check
    handle /health {
        header Content-Type application/json
        respond `{"status":"ok"}` 200
    }

    # LLM
    handle /v1/chat/completions* {
        reverse_proxy llama-llm:8080
    }
    handle /v1/completions* {
        reverse_proxy llama-llm:8080
    }
    handle /completion* {
        reverse_proxy llama-llm:8080
    }

    # Embeddings
    handle /v1/embeddings* {
        reverse_proxy llama-embeddings:8081
    }
    handle /embedding* {
        reverse_proxy llama-embeddings:8081
    }

    # Reranking
    handle /v1/rerank* {
        reverse_proxy llama-reranker:8082
    }
    handle /v1/reranking* {
        reverse_proxy llama-reranker:8082
    }
    handle /rerank* {
        reverse_proxy llama-reranker:8082
    }
    handle /reranking* {
        reverse_proxy llama-reranker:8082
    }

    # Metrics
    handle /metrics* {
        reverse_proxy llama-llm:8080
    }
    handle /stats* {
        reverse_proxy llama-llm:8080
    }

    respond "Not Found" 404
}
